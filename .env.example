# URL pública do site (sem barra final). Usado em sitemap.xml, robots.txt,
# canonical, JSON-LD e Open Graph. Defina no provedor de deploy (Vercel, etc.).
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com.br

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Verificação dos painéis de Webmaster (opcional, recomendado para SEO).
# Pegue cada token na opção "HTML tag" do painel correspondente.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Basic Auth (gate do site para testes restritos a usuários do Supabase).
# Defina para ATIVAR a proteção. Deixe em branco para liberar o site.
# Gere uma string aleatória forte (>= 32 chars). Ex.: openssl rand -hex 32
BASIC_AUTH_SECRET=
